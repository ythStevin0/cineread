# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
# Dapatkan dari: https://cloud.mongodb.com
# Connect → Drivers → copy connection string
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/cineread

# ── Third-party APIs ─────────────────────────────────────────
# TMDB: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Google Books: https://console.cloud.google.com
# APIs & Services → Library → Books API → Enable → Create Credentials
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# ── Auth — Sprint 2 ──────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_strong_random_secret_here
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Development : http://localhost:5173
# Production  : https://cineread.vercel.app
FRONTEND_URL=http://localhost:5173